#!/usr/bin/env bash
set -eu

CLAUDE_DIR="${HOME}/.claude"
CREDENTIALS="${CLAUDE_DIR}/.credentials.json"
STATS_CACHE="${CLAUDE_DIR}/stats-cache.json"
PROJECTS_DIR="${CLAUDE_DIR}/projects"
PRICING_CACHE="${CLAUDE_DIR}/pricing-cache.json"
USAGE_CACHE="${CLAUDE_DIR}/usage-cache.json"
USAGE_CACHE_TTL=120  # seconds
LITELLM_URL="https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json"

# Where the per-host summaries live. Each Claude host writes
# ${CLAUDE_SUMMARIES_DIR}/${host}/personal/summary.json on a 10-minute
# systemd timer; the widget on gnomon reads all of them here instead
# of crawling everyone's JSONL itself. Override-able for tests.
CLAUDE_SUMMARIES_DIR="${CLAUDE_SUMMARIES_DIR:-/mnt/claude}"

CLAUDE_VERSION=$(claude --version 2>/dev/null | head -1 | grep -oP '[\d.]+' || echo "2.0.0")
TODAY=$(date +%Y-%m-%d)
# Calendar week: Monday to Sunday
DOW=$(date +%u)  # 1=Monday, 7=Sunday
WEEK_START=$(date -d "$((DOW - 1)) days ago" +%Y-%m-%d)
# Calendar month: 1st of current month
MONTH_START=$(date +%Y-%m-01)

# Defaults
SUBSCRIPTION_TYPE="unknown"
RATE_LIMIT_TIER="unknown"
FIVE_HOUR_UTIL=0
FIVE_HOUR_RESET=""
SEVEN_DAY_UTIL=0
SEVEN_DAY_RESET=""
EXTRA_USAGE_ENABLED="false"

WEEK_TOKENS=0
WEEK_MESSAGES=0
WEEK_SESSIONS=0
MONTH_TOKENS=0
WEEK_MODELS=""
DAILY="0,0,0,0,0,0,0"

TODAY_COST="0.00"
WEEK_COST="0.00"
MONTH_COST="0.00"
DAILY_COSTS="0,0,0,0,0,0,0"

# Work-profile costs aggregated across all hosts' work/summary.json files.
# Unlike personal totals, these are not augmented by the local JSONL pass —
# the per-host summaries are the sole source of truth.
WORK_TODAY_COST="0.00"
WORK_WEEK_COST="0.00"
WORK_MONTH_COST="0.00"

# Backend-split work costs. Bedrock = real AWS $ (us. cross-region rate).
# API = Anthropic list price, which is the real charge only under an API
# key; under a flat subscription (WORK_ANTHROPIC_BILLING=subscription) the
# marginal cost is $0 and the widget should show utilization, not dollars.
WORK_BEDROCK_TODAY_COST="0.00"
WORK_BEDROCK_WEEK_COST="0.00"
WORK_BEDROCK_MONTH_COST="0.00"
WORK_API_TODAY_COST="0.00"
WORK_API_WEEK_COST="0.00"
WORK_API_MONTH_COST="0.00"
WORK_ANTHROPIC_BILLING="unknown"
WORK_SUBSCRIPTION_TYPE=""

ALLTIME_SESSIONS=0
ALLTIME_MESSAGES=0
FIRST_SESSION="unknown"

# --- Pricing cache (refresh once per day from LiteLLM) ---
PRICING_JSON=""
refresh_pricing() {
    local raw
    raw=$(curl -s --max-time 10 "$LITELLM_URL" 2>/dev/null) || return 1
    # Dynamically extract pricing for all Claude model families
    # Pattern: "claude-{family}-{major}-{minor}" (no date suffix, no provider prefix)
    # Groups by family name, takes the latest version per family
    # `models` = Anthropic list rate (msg_01*/API key). `bedrock_models` =
    # us.* cross-region inference-profile rate (msg_bdrk_*), ~10% above the
    # base SKU and what this deployment invokes (us-east-2). Both group by
    # family, latest version.
    local result
    result=$(echo "$raw" | jq -c '
        def latest_per_family(re):
            [ to_entries[]
              | select(.key | test(re))
              | select(.value.input_cost_per_token > 0)
              | { family: (.key | split("-") | .[1]), key: .key, value: .value } ]
            | group_by(.family)
            | map(sort_by(.key) | last
                | {key: .family, value: {
                      input: .value.input_cost_per_token,
                      output: .value.output_cost_per_token,
                      cache_read: .value.cache_read_input_token_cost,
                      cache_write: .value.cache_creation_input_token_cost
                  }})
            | from_entries;
        {
            updated: "'"$TODAY"'",
            models: latest_per_family("^claude-[a-z]+-[0-9]+-[0-9]+$"),
            bedrock_models: latest_per_family("^us\\.anthropic\\.claude-[a-z]+-[0-9]")
        }' 2>/dev/null) || return 1
    # Fetch USD→EUR exchange rate from ECB via Frankfurter
    local eur_rate
    eur_rate=$(curl -s --max-time 5 "https://api.frankfurter.app/latest?from=USD&to=EUR" 2>/dev/null \
        | jq -r '.rates.EUR // empty' 2>/dev/null) || eur_rate=""
    if [ -n "$eur_rate" ] && [[ "$eur_rate" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        result=$(echo "$result" | jq -c '. + {usd_eur_rate: '"$eur_rate"'}' 2>/dev/null)
    fi

    # Validate that we got at least one model with pricing
    local check
    check=$(echo "$result" | jq -r '.models | to_entries | length' 2>/dev/null) || return 1
    [ "$check" -gt 0 ] 2>/dev/null && echo "$result" > "$PRICING_CACHE" && return 0
    return 1
}

if [ -f "$PRICING_CACHE" ]; then
    cached_date=$(jq -r '.updated // ""' "$PRICING_CACHE" 2>/dev/null || echo "")
    # Refresh on a new day OR when the cache predates the bedrock_models
    # schema (so the Bedrock rate table gets populated on upgrade).
    if [ "$cached_date" != "$TODAY" ] || ! jq -e '.bedrock_models' "$PRICING_CACHE" >/dev/null 2>&1; then
        refresh_pricing || true
    fi
    PRICING_JSON=$(cat "$PRICING_CACHE")
else
    refresh_pricing || true
    [ -f "$PRICING_CACHE" ] && PRICING_JSON=$(cat "$PRICING_CACHE")
fi

# Build awk-friendly pricing string: "opus:input:output:cache_read:cache_write,sonnet:...,haiku:..."
PRICING_AWK=""
USD_EUR_RATE="0"
if [ -n "$PRICING_JSON" ]; then
    PRICING_AWK=$(echo "$PRICING_JSON" | jq -r '
        [.models | to_entries[] | "\(.key):\(.value.input):\(.value.output):\(.value.cache_read):\(.value.cache_write)"]
        | join(",")' 2>/dev/null || echo "")
    USD_EUR_RATE=$(echo "$PRICING_JSON" | jq -r '.usd_eur_rate // 0' 2>/dev/null || echo "0")
fi

# --- Subscription & API Usage (with cache to avoid rate limits) ---
if [ -f "$CREDENTIALS" ]; then
    SUBSCRIPTION_TYPE=$(jq -r '.claudeAiOauth.subscriptionType // "unknown"' "$CREDENTIALS")
    RATE_LIMIT_TIER=$(jq -r '.claudeAiOauth.rateLimitTier // "unknown"' "$CREDENTIALS")

    # Check if cached usage data is still fresh
    USE_CACHE=false
    if [ -f "$USAGE_CACHE" ]; then
        cache_ts=$(jq -r '.cached_at // 0' "$USAGE_CACHE" 2>/dev/null || echo 0)
        now_ts=$(date +%s)
        age=$(( now_ts - cache_ts ))
        if [ "$age" -lt "$USAGE_CACHE_TTL" ]; then
            USE_CACHE=true
        fi
    fi

    if [ "$USE_CACHE" = true ]; then
        API_RESPONSE=$(jq -r '.data' "$USAGE_CACHE" 2>/dev/null || echo '{}')
    else
        TOKEN=$(jq -r '.claudeAiOauth.accessToken // ""' "$CREDENTIALS")
        if [ -n "$TOKEN" ]; then
            API_RESPONSE=$(curl -s --max-time 5 \
                -H "Authorization: Bearer $TOKEN" \
                -H "Accept: application/json" \
                -H "Content-Type: application/json" \
                -H "User-Agent: claude-code/${CLAUDE_VERSION}" \
                -H "anthropic-beta: oauth-2025-04-20" \
                "https://api.anthropic.com/api/oauth/usage" 2>/dev/null || echo '{}')

            # Cache successful responses (no error field)
            if echo "$API_RESPONSE" | jq -e '.five_hour' >/dev/null 2>&1; then
                jq -n --argjson data "$API_RESPONSE" '{cached_at: (now | floor), data: $data}' > "$USAGE_CACHE" 2>/dev/null
            elif [ -f "$USAGE_CACHE" ]; then
                # On rate limit or error, use stale cache if available
                API_RESPONSE=$(jq -r '.data' "$USAGE_CACHE" 2>/dev/null || echo '{}')
            fi
        fi
    fi

    FIVE_HOUR_UTIL=$(echo "$API_RESPONSE" | jq -r '.five_hour.utilization // 0')
    FIVE_HOUR_RESET=$(echo "$API_RESPONSE" | jq -r '.five_hour.resets_at // ""')
    SEVEN_DAY_UTIL=$(echo "$API_RESPONSE" | jq -r '.seven_day.utilization // 0')
    SEVEN_DAY_RESET=$(echo "$API_RESPONSE" | jq -r '.seven_day.resets_at // ""')
    EXTRA_USAGE_ENABLED=$(echo "$API_RESPONSE" | jq -r '.extra_usage.is_enabled // false')
fi

# --- Token consumption from JSONL session files ---
if [ -d "$PROJECTS_DIR" ]; then
    # Calendar week dates: Monday (index 1) to Sunday (index 7)
    DAY_DATES=""
    for i in $(seq 0 6); do
        d=$(date -d "$WEEK_START + ${i} days" +%Y-%m-%d)
        DAY_DATES="${DAY_DATES:+${DAY_DATES},}${d}"
    done

    # Single pass: extract granular tokens per message, aggregate with awk
    while IFS='=' read -r key value; do
        case "$key" in
            WEEK_TOKENS) WEEK_TOKENS="$value" ;;
            WEEK_MESSAGES) WEEK_MESSAGES="$value" ;;
            WEEK_SESSIONS) WEEK_SESSIONS="$value" ;;
            MONTH_TOKENS) MONTH_TOKENS="$value" ;;
            DAILY) DAILY="$value" ;;
            WEEK_MODELS) WEEK_MODELS="$value" ;;
            TODAY_COST) TODAY_COST="$value" ;;
            WEEK_COST) WEEK_COST="$value" ;;
            MONTH_COST) MONTH_COST="$value" ;;
            DAILY_COSTS) DAILY_COSTS="$value" ;;
        esac
    done < <(find -H "$PROJECTS_DIR" -name "*.jsonl" -mtime -31 -exec cat {} + 2>/dev/null \
        | jq -r -R 'fromjson? | select(.type == "assistant") | "\(.timestamp[:10]) \(.message.model // "unknown") \(.message.usage.input_tokens // 0) \(.message.usage.output_tokens // 0) \(.message.usage.cache_read_input_tokens // 0) \(.message.usage.cache_creation_input_tokens // 0) \(.sessionId // "unknown")"' \
        | awk -v week_start="$WEEK_START" -v month_start="$MONTH_START" -v today="$TODAY" -v day_dates="$DAY_DATES" -v pricing="$PRICING_AWK" '
        BEGIN {
            split(day_dates, dates, ",")
            # Parse pricing: "opus:in:out:cr:cw,sonnet:in:out:cr:cw,haiku:in:out:cr:cw"
            has_pricing = 0
            if (pricing != "") {
                n = split(pricing, pmodels, ",")
                for (i = 1; i <= n; i++) {
                    split(pmodels[i], pp, ":")
                    price_in[pp[1]] = pp[2] + 0
                    price_out[pp[1]] = pp[3] + 0
                    price_cr[pp[1]] = pp[4] + 0
                    price_cw[pp[1]] = pp[5] + 0
                }
                has_pricing = 1
            }
        }
        {
            date = $1; model = $2
            inp = $3 + 0; out = $4 + 0; cr = $5 + 0; cw = $6 + 0
            sess = $7
            total = inp + out + cr + cw

            # Extract family from model name (claude-{family}-{version...})
            n_parts = split(model, mparts, "-")
            family = (n_parts >= 3 && mparts[1] == "claude") ? mparts[2] : model

            # Token aggregation (same as before)
            day[date] += total
            if (date >= week_start) {
                week_model[family] += total
                week_tokens += total
                week_msgs++
                week_sess[sess] = 1
            }
            if (date >= month_start) month_tokens += total

            # Cost calculation
            if (has_pricing && (family in price_in)) {
                cost = inp * price_in[family] + out * price_out[family] + cr * price_cr[family] + cw * price_cw[family]
                day_cost[date] += cost
                if (date >= week_start) week_cost += cost
                if (date >= month_start) month_cost += cost
            }
        }
        END {
            printf "WEEK_TOKENS=%d\n", week_tokens + 0
            printf "WEEK_MESSAGES=%d\n", week_msgs + 0
            n = 0; for (s in week_sess) n++
            printf "WEEK_SESSIONS=%d\n", n
            printf "MONTH_TOKENS=%d\n", month_tokens + 0

            daily = ""
            for (i = 1; i <= 7; i++) {
                val = (dates[i] in day) ? day[dates[i]] : 0
                daily = daily (i > 1 ? "," : "") val + 0
            }
            printf "DAILY=%s\n", daily

            models = ""
            first = 1
            for (m in week_model) {
                if (week_model[m] > 0) {
                    models = models (first ? "" : ",") m ":" week_model[m]
                    first = 0
                }
            }
            printf "WEEK_MODELS=%s\n", models

            # Cost outputs
            daily_costs = ""
            for (i = 1; i <= 7; i++) {
                val = (dates[i] in day_cost) ? day_cost[dates[i]] : 0
                daily_costs = daily_costs (i > 1 ? "," : "") sprintf("%.2f", val)
            }
            printf "DAILY_COSTS=%s\n", daily_costs
            printf "TODAY_COST=%.2f\n", (today in day_cost) ? day_cost[today] : 0
            printf "WEEK_COST=%.2f\n", week_cost + 0
            printf "MONTH_COST=%.2f\n", month_cost + 0
        }')
fi

# --- Cross-host aggregation from per-host summary files ---
# Each in-scope Claude host writes ${CLAUDE_SUMMARIES_DIR}/${host}/personal/summary.json
# every 10 minutes. We aggregate them into the same fields the local
# JSONL pass populates — adding to whatever's already there. This is the
# only thing that needs cross-host data; we never crawl remote JSONL.
#
# Local host's contribution: if a summary file exists for THIS host, we
# include it like any other. The local JSONL pass above already counted
# this host's data; to avoid double-counting we SKIP the same-host
# summary when local JSONL was actually processed.
HOST_BREAKDOWN=""
if [ -d "$CLAUDE_SUMMARIES_DIR" ]; then
    LOCAL_HOSTNAME="$(uname -n)"
    # Per-host today_tokens used to build HOST_BREAKDOWN (sorted desc).
    # awk gives us numeric sort without pulling sort(1)'s -k --version-sort fuss.
    BREAK_RAW=""
    for sum in "$CLAUDE_SUMMARIES_DIR"/*/personal/summary.json; do
        [ -f "$sum" ] || continue
        host=$(jq -r '.host // ""' "$sum" 2>/dev/null || echo "")
        [ -n "$host" ] || continue

        s_today_tokens=$(jq -r '.today_tokens // 0'   "$sum" 2>/dev/null || echo 0)
        s_today_cost=$(jq -r   '.today_cost_usd // 0' "$sum" 2>/dev/null || echo 0)
        s_week_tokens=$(jq -r  '.week_tokens // 0'    "$sum" 2>/dev/null || echo 0)
        s_week_cost=$(jq -r    '.week_cost_usd // 0'  "$sum" 2>/dev/null || echo 0)
        s_week_msgs=$(jq -r    '.week_messages // 0'  "$sum" 2>/dev/null || echo 0)
        s_week_sess=$(jq -r    '.week_sessions // 0'  "$sum" 2>/dev/null || echo 0)
        s_month_tokens=$(jq -r '.month_tokens // 0'   "$sum" 2>/dev/null || echo 0)
        s_month_cost=$(jq -r   '.month_cost_usd // 0' "$sum" 2>/dev/null || echo 0)
        s_daily=$(jq -r        '.daily_tokens | @csv'      "$sum" 2>/dev/null || echo "0,0,0,0,0,0,0")
        s_dailyc=$(jq -r       '.daily_costs  | @csv'      "$sum" 2>/dev/null || echo "0,0,0,0,0,0,0")
        s_models=$(jq -r       '.week_per_model | to_entries | map("\(.key):\(.value)") | join(",")' "$sum" 2>/dev/null || echo "")

        # Don't double-count local host (local JSONL pass above already did).
        if [ "$host" = "$LOCAL_HOSTNAME" ] && [ -d "$PROJECTS_DIR" ]; then
            # We still want today_tokens for HOST_BREAKDOWN — use local
            # totals which are at least as fresh.
            : "use local values; below adds to BREAK_RAW from local pass"
        else
            # Aggregate scalars
            WEEK_TOKENS=$((WEEK_TOKENS + s_week_tokens))
            WEEK_MESSAGES=$((WEEK_MESSAGES + s_week_msgs))
            WEEK_SESSIONS=$((WEEK_SESSIONS + s_week_sess))
            MONTH_TOKENS=$((MONTH_TOKENS + s_month_tokens))
            TODAY_COST=$(awk -v a="$TODAY_COST" -v b="$s_today_cost"  'BEGIN{printf "%.2f", a + b}')
            WEEK_COST=$(awk  -v a="$WEEK_COST"  -v b="$s_week_cost"   'BEGIN{printf "%.2f", a + b}')
            MONTH_COST=$(awk -v a="$MONTH_COST" -v b="$s_month_cost"  'BEGIN{printf "%.2f", a + b}')

            # Aggregate DAILY arrays (CSV of 7 ints / floats)
            DAILY=$(awk -F, -v a="$DAILY" -v b="$s_daily" 'BEGIN{
                na = split(a, aa, ","); split(b, bb, ",")
                for (i = 1; i <= 7; i++) printf "%d%s", (aa[i]+0)+(bb[i]+0), (i<7?",":"\n")
            }')
            DAILY_COSTS=$(awk -F, -v a="$DAILY_COSTS" -v b="$s_dailyc" 'BEGIN{
                na = split(a, aa, ","); split(b, bb, ",")
                for (i = 1; i <= 7; i++) printf "%.2f%s", (aa[i]+0)+(bb[i]+0), (i<7?",":"\n")
            }')

            # Merge WEEK_MODELS — combine family:tokens entries
            WEEK_MODELS=$(awk -v a="$WEEK_MODELS" -v b="$s_models" 'BEGIN{
                n = split(a, aa, ","); for (i=1;i<=n;i++) { split(aa[i], p, ":"); if (p[1]!="") tot[p[1]] += p[2]+0 }
                n = split(b, bb, ","); for (i=1;i<=n;i++) { split(bb[i], p, ":"); if (p[1]!="") tot[p[1]] += p[2]+0 }
                first = 1
                for (k in tot) { printf "%s%s:%d", (first?"":","), k, tot[k]; first = 0 }
                if (first) printf ""  # empty
                printf "\n"
            }')
        fi

        # HOST_BREAKDOWN: include this host's today_tokens for ALL hosts
        # (including local if no local JSONL pass — falls back to summary).
        if [ "$host" = "$LOCAL_HOSTNAME" ] && [ -d "$PROJECTS_DIR" ]; then
            # Local pass already computed today_tokens into DAILY[todayIdx];
            # use the summary's value as a fallback if local was zero.
            t_for_break="$s_today_tokens"
        else
            t_for_break="$s_today_tokens"
        fi
        if [ "$t_for_break" -gt 0 ] 2>/dev/null; then
            BREAK_RAW="${BREAK_RAW}${BREAK_RAW:+
}${t_for_break} ${host}"
        fi
    done

    # Sort BREAK_RAW desc by today_tokens, format as "host:tokens,host:tokens,..."
    if [ -n "$BREAK_RAW" ]; then
        HOST_BREAKDOWN=$(echo "$BREAK_RAW" | sort -rn | awk '{printf "%s%s:%d", (NR==1?"":","), $2, $1}')
    fi

    # --- Work-profile cost aggregation ---
    # Sums today/week/month_cost_usd from every host's work/summary.json,
    # INCLUDING the local host. No local-JSONL pass exists for work, so
    # the work summaries are authoritative — no double-count to avoid.
    # A missing or malformed file contributes 0 and never aborts the loop.
    for sum in "$CLAUDE_SUMMARIES_DIR"/*/work/summary.json; do
        [ -f "$sum" ] || continue
        s_today_cost=$(jq -r '.today_cost_usd // 0' "$sum" 2>/dev/null || echo 0)
        s_week_cost=$(jq -r  '.week_cost_usd // 0'  "$sum" 2>/dev/null || echo 0)
        s_month_cost=$(jq -r '.month_cost_usd // 0' "$sum" 2>/dev/null || echo 0)
        WORK_TODAY_COST=$(awk -v a="$WORK_TODAY_COST" -v b="$s_today_cost" 'BEGIN{printf "%.2f", a + b}')
        WORK_WEEK_COST=$(awk  -v a="$WORK_WEEK_COST"  -v b="$s_week_cost"  'BEGIN{printf "%.2f", a + b}')
        WORK_MONTH_COST=$(awk -v a="$WORK_MONTH_COST" -v b="$s_month_cost" 'BEGIN{printf "%.2f", a + b}')

        # Backend split (fields absent on pre-upgrade summaries → 0).
        sb_today=$(jq -r '.today_bedrock_cost_usd // 0' "$sum" 2>/dev/null || echo 0)
        sb_week=$(jq -r  '.week_bedrock_cost_usd // 0'  "$sum" 2>/dev/null || echo 0)
        sb_month=$(jq -r '.month_bedrock_cost_usd // 0' "$sum" 2>/dev/null || echo 0)
        sa_today=$(jq -r '.today_api_cost_usd // 0'     "$sum" 2>/dev/null || echo 0)
        sa_week=$(jq -r  '.week_api_cost_usd // 0'      "$sum" 2>/dev/null || echo 0)
        sa_month=$(jq -r '.month_api_cost_usd // 0'     "$sum" 2>/dev/null || echo 0)
        WORK_BEDROCK_TODAY_COST=$(awk -v a="$WORK_BEDROCK_TODAY_COST" -v b="$sb_today" 'BEGIN{printf "%.2f", a + b}')
        WORK_BEDROCK_WEEK_COST=$(awk  -v a="$WORK_BEDROCK_WEEK_COST"  -v b="$sb_week"  'BEGIN{printf "%.2f", a + b}')
        WORK_BEDROCK_MONTH_COST=$(awk -v a="$WORK_BEDROCK_MONTH_COST" -v b="$sb_month" 'BEGIN{printf "%.2f", a + b}')
        WORK_API_TODAY_COST=$(awk -v a="$WORK_API_TODAY_COST" -v b="$sa_today" 'BEGIN{printf "%.2f", a + b}')
        WORK_API_WEEK_COST=$(awk  -v a="$WORK_API_WEEK_COST"  -v b="$sa_week"  'BEGIN{printf "%.2f", a + b}')
        WORK_API_MONTH_COST=$(awk -v a="$WORK_API_MONTH_COST" -v b="$sa_month" 'BEGIN{printf "%.2f", a + b}')

        # Billing mode: any host reporting a subscription wins (flat plan ⇒
        # API-side marginal cost is $0). subtype is the richest seen.
        s_billing=$(jq -r '.anthropic_billing // "unknown"' "$sum" 2>/dev/null || echo "unknown")
        s_subtype=$(jq -r '.subscription_type // ""' "$sum" 2>/dev/null || echo "")
        if [ "$s_billing" = "subscription" ]; then WORK_ANTHROPIC_BILLING="subscription"; fi
        if [ "$WORK_ANTHROPIC_BILLING" = "unknown" ] && [ "$s_billing" != "unknown" ]; then WORK_ANTHROPIC_BILLING="$s_billing"; fi
        [ -n "$s_subtype" ] && WORK_SUBSCRIPTION_TYPE="$s_subtype"
    done
fi

# --- 7-day projection (extrapolate utilization to reset) ---
PROJECTED_SEVEN_DAY="0"
SEVEN_DAY_DELTA="0"
SEVEN_DAY_ELAPSED_FRAC="0"
if [ -n "$SEVEN_DAY_RESET" ]; then
    # epoch arithmetic. SEVEN_DAY_RESET is ISO 8601 with timezone.
    reset_epoch=$(date -d "$SEVEN_DAY_RESET" +%s 2>/dev/null || echo 0)
    now_epoch=$(date +%s)
    if [ "$reset_epoch" -gt 0 ]; then
        # 7-day window = 604800 seconds. elapsed = now - (reset - 7d).
        window_start=$((reset_epoch - 604800))
        elapsed_s=$((now_epoch - window_start))
        # awk for the float math
        read -r PROJECTED_SEVEN_DAY SEVEN_DAY_DELTA SEVEN_DAY_ELAPSED_FRAC <<<"$(
            awk -v util="$SEVEN_DAY_UTIL" -v elapsed="$elapsed_s" 'BEGIN{
                frac = elapsed / 604800.0
                if (frac < 0) frac = 0
                if (frac > 1) frac = 1
                # Only project once meaningful time has elapsed (>1% of window
                # = ~1.7h). Before that the extrapolation is wildly noisy.
                if (frac > 0.01) {
                    projected = util / frac
                } else {
                    projected = 0
                }
                printf "%.1f %.1f %.3f\n", projected, projected - 100, frac
            }'
        )"
    fi
fi

# --- All-time from stats cache (supplementary) ---
if [ -f "$STATS_CACHE" ]; then
    ALLTIME_SESSIONS=$(jq -r '.totalSessions // 0' "$STATS_CACHE" 2>/dev/null || echo 0)
    ALLTIME_MESSAGES=$(jq -r '.totalMessages // 0' "$STATS_CACHE" 2>/dev/null || echo 0)
    FIRST_SESSION=$(jq -r '.firstSessionDate // "unknown"' "$STATS_CACHE" 2>/dev/null || echo "unknown")
    FIRST_SESSION="${FIRST_SESSION%%T*}"
fi

