#!/usr/bin/env bash
# Per-host, per-profile transcript summarizer for Claude Code.
#
# Reads $HOME/.claude{,-work}/projects/**/*.jsonl, computes today/week
# token + cost totals plus per-model breakdown, writes a single small
# JSON file. Designed to run on a 10-minute systemd user timer; one
# invocation per profile.
#
# The output is consumed by `get-claude-usage` running on the bar host
# (gnomon): it aggregates the summary.json from every host's NFS bucket
# instead of crawling all the JSONL files itself. That keeps the
# Synology platter drives quiet during widget polling.
#
# Schema:
#   {
#     "host": "ultraviolet",
#     "profile": "personal",
#     "generated_at": "ISO-8601",
#     "today_tokens": int,
#     "today_cost_usd": float,
#     "today_per_model": { family: tokens, ... },
#     "week_tokens": int,
#     "week_cost_usd": float,
#     "week_messages": int,
#     "week_sessions": int,
#     "week_per_model": { family: tokens, ... },
#     "month_tokens": int,
#     "month_cost_usd": float,
#     "daily_tokens": [Mon..Sun]   # calendar week
#     "daily_costs":  [Mon..Sun]
#   }
#
# No `set -o pipefail` on the big find|jq|awk pipeline — partial-file
# tolerance matches the get-claude-usage convention.
set -eu

PROFILE=""
OUT=""

while [ $# -gt 0 ]; do
    case "$1" in
        --profile) PROFILE="${2:-}"; shift 2 ;;
        --out)     OUT="${2:-}";     shift 2 ;;
        -h|--help)
            sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) echo "claude-usage-summary: unknown arg: $1" >&2; exit 2 ;;
    esac
done

[ -n "$PROFILE" ] || { echo "claude-usage-summary: --profile required" >&2; exit 2; }
[ -n "$OUT" ]     || { echo "claude-usage-summary: --out required" >&2; exit 2; }

case "$PROFILE" in
    personal) PROFILE_DIR="$HOME/.claude" ;;
    work)     PROFILE_DIR="$HOME/.claude-work" ;;
    *) echo "claude-usage-summary: unknown profile '$PROFILE' (expected personal|work)" >&2; exit 2 ;;
esac

PROJECTS="$PROFILE_DIR/projects"
PRICING_CACHE="$HOME/.claude/pricing-cache.json"
LITELLM_URL="https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json"

HOSTNAME_NOW="$(uname -n)"
TODAY=$(date +%Y-%m-%d)
DOW=$(date +%u)  # 1=Mon..7=Sun
WEEK_START=$(date -d "$((DOW - 1)) days ago" +%Y-%m-%d)
MONTH_START=$(date +%Y-%m-01)
GENERATED="$(date -Iseconds)"

# Self-bootstrap the pricing cache. On hosts that never run
# get-claude-usage (any host that isn't gnomon — the only widget host),
# ~/.claude/pricing-cache.json would otherwise never exist and every
# cost computation here would silently yield zero despite real token
# usage. Fetch from LiteLLM once per day; on failure leave costs at
# zero rather than abort the summary run.
refresh_pricing() {
    local raw result eur_rate check
    raw=$(curl -s --max-time 10 "$LITELLM_URL" 2>/dev/null) || return 1
    result=$(echo "$raw" | jq -c '{
        updated: "'"$TODAY"'",
        models: ([to_entries[]
            | select(.key | test("^claude-[a-z]+-[0-9]+-[0-9]+$"))
            | select(.value.input_cost_per_token > 0)
            | { family: (.key | split("-") | .[1]), key: .key, value: .value }
        ] | group_by(.family)
          | map(sort_by(.key) | last
              | {key: .family, value: {
                    input: .value.input_cost_per_token,
                    output: .value.output_cost_per_token,
                    cache_read: .value.cache_read_input_token_cost,
                    cache_write: .value.cache_creation_input_token_cost
                }})
          | from_entries)
    }' 2>/dev/null) || return 1
    eur_rate=$(curl -s --max-time 5 "https://api.frankfurter.app/latest?from=USD&to=EUR" 2>/dev/null \
        | jq -r '.rates.EUR // empty' 2>/dev/null) || eur_rate=""
    if [ -n "$eur_rate" ] && [[ "$eur_rate" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        result=$(echo "$result" | jq -c '. + {usd_eur_rate: '"$eur_rate"'}' 2>/dev/null)
    fi
    check=$(echo "$result" | jq -r '.models | to_entries | length' 2>/dev/null) || return 1
    [ "$check" -gt 0 ] 2>/dev/null && mkdir -p "$(dirname "$PRICING_CACHE")" && echo "$result" > "$PRICING_CACHE" && return 0
    return 1
}

# Only refresh when the cache is entirely missing — this is the
# bootstrap path for hosts that never run get-claude-usage. Staleness
# is gnomon's responsibility via get-claude-usage's daily refresh; we
# don't want every host hammering LiteLLM and we don't want tests with
# pre-seeded stale caches to trigger network calls.
if [ ! -f "$PRICING_CACHE" ]; then
    refresh_pricing || true
fi

# Awk-friendly pricing string: "opus:input:output:cache_read:cache_write,sonnet:...,haiku:..."
# Personal-profile pricing-cache.json is reused across profiles — pricing is
# global, not per-profile. If still unavailable after refresh attempt (no
# network, etc.), costs come out as zero and the bar shows token totals only.
PRICING_AWK=""
if [ -f "$PRICING_CACHE" ]; then
    PRICING_AWK=$(jq -r '
        [.models | to_entries[]
         | "\(.key):\(.value.input):\(.value.output):\(.value.cache_read):\(.value.cache_write)"]
        | join(",")' "$PRICING_CACHE" 2>/dev/null || echo "")
fi

emit_zero() {
    mkdir -p "$(dirname "$OUT")"
    jq -n --arg host "$HOSTNAME_NOW" --arg profile "$PROFILE" --arg generated "$GENERATED" \
        '{host: $host, profile: $profile, generated_at: $generated,
          today_tokens: 0, today_cost_usd: 0, today_per_model: {},
          week_tokens: 0,  week_cost_usd: 0,  week_per_model: {},
          week_messages: 0, week_sessions: 0,
          month_tokens: 0, month_cost_usd: 0,
          daily_tokens: [0,0,0,0,0,0,0], daily_costs: [0,0,0,0,0,0,0]}' \
        > "$OUT.tmp" && mv "$OUT.tmp" "$OUT"
}

if [ ! -d "$PROJECTS" ]; then
    emit_zero
    exit 0
fi

# Calendar-week dates Mon..Sun, comma-separated for awk.
DAY_DATES=""
for i in 0 1 2 3 4 5 6; do
    d=$(date -d "$WEEK_START + ${i} days" +%Y-%m-%d)
    DAY_DATES="${DAY_DATES:+${DAY_DATES},}${d}"
done

# Single pass: extract granular tokens per assistant message, aggregate
# with awk. JSON encoding is built up by awk (no second jq round-trip).
# `find -H` follows the start path if it's a symlink (PROJECTS is
# typically ~/.claude/projects -> /mnt/claude/$HOST/personal/projects)
# but does NOT follow symlinks encountered during traversal — avoids
# the classic "find returns nothing because PROJECTS is a symlink" trap.
RESULT=$(find -H "$PROJECTS" -name '*.jsonl' -mtime -31 -exec cat {} + 2>/dev/null \
    | jq -r -R 'fromjson?
        # Canonical filter set, ported from ccusage v15.0.0 src/data-loader.ts:
        #   - .type == "assistant" (only billed responses; user/system/etc. are free)
        #   - .isSidechain != true   (subagent re-logs of the parent conversation
        #                             have separate cache_read accounting but
        #                             Claude Code-specific overcounts in known
        #                             ccusage issue #913)
        #   - .message.model != "<synthetic>" (placeholder/error rows with full
        #                                      token counts but no actual API call)
        #   - .message.usage present (records without usage are not billed)
        | select(.type == "assistant"
                 and (.isSidechain // false) == false
                 and (.message.model // "") != "<synthetic>"
                 and (.message.usage // null) != null)
        # Emit LOCAL date (TZ of the machine running this script), not the
        # UTC prefix of the timestamp. Anthropic/Bedrock JSONL timestamps
        # are UTC; comparing their date prefix against bash $TODAY (which
        # is local-tz) mis-classified ~7h of late-local-yesterday activity
        # as "today" for PDT users. fromdateiso8601 needs the milliseconds
        # stripped, hence the [:19] + "Z" trim.
        #
        # Dedup key is `message.id:requestId`, also ported from ccusage
        # (issue #389): Claude Code emits the SAME message.id twice per
        # assistant turn (once for the text part and once for the
        # tool_use part) with identical usage blocks. Both carry the
        # same requestId, so this joint key collapses them. The "no-id"
        # / "no-req" fallbacks are kept distinct so legacy fixtures
        # without these fields are not all collapsed into one row.
        | "\(((.timestamp[:19]) + "Z") | fromdateiso8601 | localtime | strftime("%Y-%m-%d")) \(.message.model // "unknown") \(.message.usage.input_tokens // 0) \(.message.usage.output_tokens // 0) \(.message.usage.cache_read_input_tokens // 0) \(.message.usage.cache_creation_input_tokens // 0) \(.sessionId // "unknown") \(.message.id // "no-id"):\(.requestId // "no-req")"' \
    | awk -v today="$TODAY" -v week_start="$WEEK_START" -v month_start="$MONTH_START" -v day_dates="$DAY_DATES" -v pricing="$PRICING_AWK" '
BEGIN {
    split(day_dates, dates, ",")
    has_pricing = 0
    if (pricing != "") {
        n = split(pricing, pmodels, ",")
        for (i = 1; i <= n; i++) {
            split(pmodels[i], pp, ":")
            price_in[pp[1]] = pp[2] + 0
            price_out[pp[1]] = pp[3] + 0
            price_cr[pp[1]] = pp[4] + 0
            price_cw[pp[1]] = pp[5] + 0
        }
        has_pricing = 1
    }
}
{
    date = $1; model = $2
    inp = $3 + 0; out = $4 + 0; cr = $5 + 0; cw = $6 + 0
    sess = $7; dedup_key = $8

    # Dedup by composite (message.id, requestId) key, matching the
    # canonical hash ccusage uses (its issue #389). Claude Code emits
    # the SAME message.id twice per assistant turn (text part +
    # tool_use part) with identical usage. Both rows carry the same
    # requestId, so the joint key collapses them. Records without
    # either field land on the "no-id:no-req" or "msg-X:no-req" key,
    # and we let those rows through (no dedup) so legacy fixtures are
    # not all collapsed together.
    if (dedup_key != "no-id:no-req") {
        if (dedup_key in seen_msg) next
        seen_msg[dedup_key] = 1
    }
    total = inp + out + cr + cw

    # Extract family from model name (claude-{family}-{version...})
    n_parts = split(model, mparts, "-")
    family = (n_parts >= 3 && mparts[1] == "claude") ? mparts[2] : model

    day_tokens[date] += total
    if (date == today) {
        today_tokens += total
        today_model[family] += total
    }
    if (date >= week_start) {
        week_tokens += total
        week_model[family] += total
        week_messages++
        week_sess[sess] = 1
    }
    if (date >= month_start) month_tokens += total

    if (has_pricing && (family in price_in)) {
        cost = inp * price_in[family] + out * price_out[family] + cr * price_cr[family] + cw * price_cw[family]
        day_cost[date] += cost
        if (date == today)       today_cost += cost
        if (date >= week_start)  week_cost  += cost
        if (date >= month_start) month_cost += cost
    }
}
END {
    # Mon..Sun arrays
    daily_t = ""; daily_c = ""
    for (i = 1; i <= 7; i++) {
        val_t = (dates[i] in day_tokens) ? day_tokens[dates[i]] : 0
        val_c = (dates[i] in day_cost)   ? day_cost[dates[i]]   : 0
        daily_t = daily_t (i > 1 ? "," : "") val_t + 0
        daily_c = daily_c (i > 1 ? "," : "") sprintf("%.4f", val_c)
    }

    # Per-model JSON objects
    tm = "{"; first = 1
    for (m in today_model) {
        tm = tm (first ? "" : ",") "\"" m "\":" today_model[m] + 0
        first = 0
    }
    tm = tm "}"

    wm = "{"; first = 1
    for (m in week_model) {
        wm = wm (first ? "" : ",") "\"" m "\":" week_model[m] + 0
        first = 0
    }
    wm = wm "}"

    # Count distinct week sessions
    n_sess = 0; for (s in week_sess) n_sess++

    # Tab-separated scalars + JSON fragments
    printf "%d\t%.4f\t%d\t%.4f\t%d\t%d\t%d\t%.4f\t[%s]\t[%s]\t%s\t%s\n", \
        today_tokens + 0, today_cost + 0, \
        week_tokens + 0, week_cost + 0, \
        week_messages + 0, n_sess + 0, \
        month_tokens + 0, month_cost + 0, \
        daily_t, daily_c, tm, wm
}')

# Empty pipeline = no assistant messages found. Emit zero summary so the
# downstream aggregator always sees a valid file.
if [ -z "$RESULT" ]; then
    emit_zero
    exit 0
fi

IFS=$'\t' read -r TODAY_TOK TODAY_COST WEEK_TOK WEEK_COST WEEK_MSGS WEEK_SESS MONTH_TOK MONTH_COST DAILY_TOK DAILY_COST TODAY_PM WEEK_PM <<<"$RESULT"

mkdir -p "$(dirname "$OUT")"
jq -n \
    --arg host "$HOSTNAME_NOW" \
    --arg profile "$PROFILE" \
    --arg generated "$GENERATED" \
    --argjson today_tokens "$TODAY_TOK" \
    --argjson today_cost "$TODAY_COST" \
    --argjson week_tokens "$WEEK_TOK" \
    --argjson week_cost "$WEEK_COST" \
    --argjson week_messages "$WEEK_MSGS" \
    --argjson week_sessions "$WEEK_SESS" \
    --argjson month_tokens "$MONTH_TOK" \
    --argjson month_cost "$MONTH_COST" \
    --argjson daily_tokens "$DAILY_TOK" \
    --argjson daily_costs "$DAILY_COST" \
    --argjson today_per_model "$TODAY_PM" \
    --argjson week_per_model "$WEEK_PM" \
    '{host: $host, profile: $profile, generated_at: $generated,
      today_tokens: $today_tokens, today_cost_usd: $today_cost,
      today_per_model: $today_per_model,
      week_tokens: $week_tokens, week_cost_usd: $week_cost,
      week_messages: $week_messages, week_sessions: $week_sessions,
      week_per_model: $week_per_model,
      month_tokens: $month_tokens, month_cost_usd: $month_cost,
      daily_tokens: $daily_tokens, daily_costs: $daily_costs}' \
    > "$OUT.tmp" && mv "$OUT.tmp" "$OUT"
